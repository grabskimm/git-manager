# When deps are installed from THIS directory (the CI "stage desktop deps" step),
# install the file:../engine dependency as a real, self-contained copy rather
# than a symlink, and keep everything in packages/desktop/node_modules instead of
# hoisting to the repo root. This is what lets electron-builder package the app
# without trying to re-install production deps (which, against a hoisted root
# node_modules, prunes app-builder-bin mid-build — electron-builder#7103).
install-links=true
