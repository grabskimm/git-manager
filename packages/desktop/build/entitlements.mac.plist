<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- The engine runs as a child process via ELECTRON_RUN_AS_NODE and loads
       native modules (better-sqlite3, node-pty), so the hardened runtime needs
       the JIT / unsigned-executable-memory allowances. -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <key>com.apple.security.cs.allow-dyld-environment-variables</key>
  <true/>
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
  <!-- GitManager manages arbitrary local repositories. -->
  <key>com.apple.security.files.user-selected.read-write</key>
  <true/>
</dict>
</plist>
